#!/usr/bin/env bash
# Certux Universal Engine v7.4 - "The Complete Foundation"

COMMAND=$1
TARGET=$2
EXTRA=$3
CONTAINER_NAME="certux-legacy-layer"
BASE_IMAGE="debian:latest"
REAL_DESKTOP_DIR="$HOME/.local/share/applications"

ensure_container() {
    if ! distrobox list | grep -q "$CONTAINER_NAME"; then
        echo "📦 Initializing Certux Subsystem..."
        distrobox create --name "$CONTAINER_NAME" --image "$BASE_IMAGE" --yes > /dev/null 2>&1
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo dpkg --add-architecture i386 && sudo apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common xdg-utils"
    fi
}

native_integration_cleanup() {
    echo "🧹 Applying Native OS Visual Integration..."
    sed -i "s/ (on ${CONTAINER_NAME})//g" "$REAL_DESKTOP_DIR/"*.desktop 2>/dev/null || true
    chmod +x "$REAL_DESKTOP_DIR/"*.desktop 2>/dev/null || true
}

case "$COMMAND" in
    search)
        if [ -z "$TARGET" ]; then echo "Usage: cert search <query>"; exit 1; fi
        echo -e "\n🔍 Searching Certux Ecosystem for: $TARGET"
        echo "=========================================================="
        echo "📦 FLATPAK (Modern Sandboxed Apps):"
        flatpak search "$TARGET" --columns=application,name,description | head -n 6
        echo "=========================================================="
        echo "📦 DEBIAN SUBSYSTEM (Legacy Apps):"
        ensure_container
        distrobox enter "$CONTAINER_NAME" -- bash -c "apt-cache search $TARGET | head -n 6"
        echo "=========================================================="
        ;;

    list)
        echo "=========================================================="
        echo "📦 SYSTEM HOST (OSTree Overlays)"
        echo "=========================================================="
        rpm-ostree status -b | grep "LocalPackages" || echo "No local host packages layered."
        echo ""
        echo "=========================================================="
        echo "📦 FLATPAK (Modern App Ecosystem)"
        echo "=========================================================="
        flatpak list --app --columns=name,application
        echo ""
        echo "=========================================================="
        echo "📦 DEBIAN SUBSYSTEM (certux-legacy-layer)"
        echo "=========================================================="
        ensure_container
        distrobox enter "$CONTAINER_NAME" -- bash -c "apt-mark showmanual"
        echo "=========================================================="
        ;;

    upgrade)
        echo "🔄 Upgrading Certux Ecosystem..."
        sudo rpm-ostree upgrade
        flatpak update -y
        if distrobox list | grep -q "$CONTAINER_NAME"; then
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y"
        fi
        echo "✅ Universal Upgrade complete!"
        ;;

    repo)
        ensure_container
        if [ "$TARGET" == "list" ]; then
            echo -e "\n--- FLATPAK REPOSITORIES ---"
            flatpak remotes
            echo -e "\n--- DEBIAN SUBSYSTEM REPOSITORIES ---"
            distrobox enter "$CONTAINER_NAME" -- bash -c "cat /etc/apt/sources.list /etc/apt/sources.list.d/*.list 2>/dev/null | grep -v '^#'"
        elif [ "$TARGET" == "add" ]; then
            if [ -z "$EXTRA" ]; then echo "Usage: cert repo add <url>"; exit 1; fi
            echo "➕ Adding repository: $EXTRA"
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-add-repository '$EXTRA' -y && sudo apt-get update"
        else
            echo "Usage: cert repo list OR cert repo add <url>"
        fi
        ;;

    install)
        if [ -z "$TARGET" ]; then echo "Usage: cert install <package/file>"; exit 1; fi
        mkdir -p "$REAL_DESKTOP_DIR"
        
        if [[ "$TARGET" == *.AppImage || "$TARGET" == *.appimage ]]; then
            BASENAME=$(basename "$TARGET")
            APP_NAME="${BASENAME%.*}"
            echo "📥 Securing AppImage..."
            cp "$TARGET" "$REAL_DESKTOP_DIR/$BASENAME"
            chmod +x "$REAL_DESKTOP_DIR/$BASENAME"
            echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=$REAL_DESKTOP_DIR/$BASENAME\nIcon=application-x-executable\nType=Application\nCategories=Utility;" > "$REAL_DESKTOP_DIR/certux-${APP_NAME}.desktop"
            echo "✅ AppImage installed!"
            native_integration_cleanup
            exit 0
        fi

        ensure_container
        if [[ -f "$TARGET" && "$TARGET" == *.deb ]]; then
            FILE_PATH=$(realpath "$TARGET")
            echo "📥 Installing local .deb: $TARGET"
            if ! distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y '$FILE_PATH'"; then
                distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get install -f -y"
            fi
            APP_NAME=$(distrobox enter "$CONTAINER_NAME" -- bash -c "dpkg-deb -f '$FILE_PATH' Package")
        else
            echo "📥 Installing web package: $TARGET"
            if ! distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y $TARGET"; then
                echo "❌ CRITICAL ERROR: Package '$TARGET' not found or failed to install."
                echo "🔍 Did you mean one of these?"
                distrobox enter "$CONTAINER_NAME" -- bash -c "apt-cache search $TARGET | head -n 5"
                exit 1
            fi
            APP_NAME="$TARGET"
        fi
        
        echo "🔎 Verifying binary exists in container..."
        BINARY_EXISTS=false
        if distrobox enter "$CONTAINER_NAME" -- bash -c "command -v $APP_NAME" > /dev/null 2>&1; then
             BINARY_EXISTS=true
             EXEC_CMD="$APP_NAME"
        else
             SHORT_NAME="${APP_NAME%%-*}"
             if distrobox enter "$CONTAINER_NAME" -- bash -c "command -v $SHORT_NAME" > /dev/null 2>&1; then
                 BINARY_EXISTS=true
                 EXEC_CMD="$SHORT_NAME"
             fi
        fi

        if [ "$BINARY_EXISTS" = false ]; then
             echo "❌ CRITICAL ERROR: Binary for '$APP_NAME' could not be found. Aborting shortcut creation."
             exit 1
        fi

        echo "🔗 Bridging $EXEC_CMD to your desktop..."
        EXPORT_SUCCESS=false

        if distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $APP_NAME --export-path $REAL_DESKTOP_DIR" > /dev/null 2>&1; then
            EXPORT_SUCCESS=true
        else
            FOUND_DESKTOP=$(distrobox enter "$CONTAINER_NAME" -- bash -c "ls /usr/share/applications | grep -i '$APP_NAME' | head -n 1")
            if [ -n "$FOUND_DESKTOP" ]; then
                CLEAN_NAME="${FOUND_DESKTOP%.desktop}"
                if distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $CLEAN_NAME --export-path $REAL_DESKTOP_DIR" > /dev/null 2>&1; then
                    EXPORT_SUCCESS=true
                fi
            elif distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $EXEC_CMD --export-path $REAL_DESKTOP_DIR" > /dev/null 2>&1; then
                EXPORT_SUCCESS=true
            fi
        fi

        if [ "$EXPORT_SUCCESS" = false ]; then
            echo "⚠️ Standard bridging failed. Engaging Brute-Force Shortcut Generator..."
            BRUTE_DESKTOP="$REAL_DESKTOP_DIR/certux-bruteforce-${APP_NAME}.desktop"
            echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=/usr/bin/distrobox-enter -n $CONTAINER_NAME -- $EXEC_CMD\nIcon=application-x-executable\nType=Application\nCategories=Utility;" > "$BRUTE_DESKTOP"
        fi

        echo "✅ Successfully installed and bridged!"
        native_integration_cleanup
        ;;

    remove)
        ensure_container
        if [ -z "$TARGET" ]; then echo "Usage: cert remove <package>"; exit 1; fi
        echo "🗑️ Removing $TARGET..."
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get remove -y $TARGET"
        rm -f "$REAL_DESKTOP_DIR/certux-bruteforce-${TARGET}.desktop" 2>/dev/null || true
        rm -f "$REAL_DESKTOP_DIR/${CONTAINER_NAME}-${TARGET}.desktop" 2>/dev/null || true
        echo "✅ Removed $TARGET."
        ;;
        
    *)
        echo -e "Certux Unified Commands:"
        echo "  cert search <query>         - Search all repositories"
        echo "  cert install <pkg/file>     - Install Web, .deb, or .AppImage"
        echo "  cert remove <pkg>           - Remove an app"
        echo "  cert upgrade                - Update entire OS"
        echo "  cert list                   - List installed apps/packages"
        echo "  cert repo list              - List all active repositories"
        echo "  cert repo add <url>         - Add a Debian PPA or repo URL"
        ;;
esac
