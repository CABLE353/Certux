#!/usr/bin/env bash
# Certux Universal Engine v5.0

COMMAND=$1
TARGET=$2
EXTRA=$3
CONTAINER_NAME="certux-legacy-layer"
BASE_IMAGE="debian:latest"

ensure_container() {
    if ! distrobox list | grep -q "$CONTAINER_NAME"; then
        echo "📦 Initializing Certux Subsystem..."
        distrobox create --name "$CONTAINER_NAME" --image "$BASE_IMAGE" --yes > /dev/null 2>&1
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo dpkg --add-architecture i386 && sudo apt-get update > /dev/null 2>&1"
    fi
}

case "$COMMAND" in
    search)
        if [ -z "$TARGET" ]; then echo "Usage: cert search <query>"; exit 1; fi
        echo "🔍 Searching Certux Ecosystem for: $TARGET"
        echo "=========================================================="
        echo "📦 FLATPAK (Modern Sandboxed Apps):"
        flatpak search "$TARGET" --columns=application,name,description | head -n 6
        echo "=========================================================="
        echo "📦 DEBIAN SUBSYSTEM (Legacy Apps):"
        ensure_container
        distrobox enter "$CONTAINER_NAME" -- bash -c "apt-cache search $TARGET | head -n 6"
        echo "=========================================================="
        ;;

    list)
        echo "=========================================================="
        echo "📦 SYSTEM HOST (OSTree Overlays)"
        echo "=========================================================="
        rpm-ostree status -b | grep "LocalPackages" || echo "No local host packages layered."
        echo ""
        echo "=========================================================="
        echo "📦 FLATPAK (Modern App Ecosystem)"
        echo "=========================================================="
        flatpak list --app --columns=name,application
        echo ""
        echo "=========================================================="
        echo "📦 DEBIAN SUBSYSTEM (certux-legacy-layer)"
        echo "=========================================================="
        ensure_container
        # Lists manually installed apt packages (filtering out dependencies for clarity)
        distrobox enter "$CONTAINER_NAME" -- bash -c "apt-mark showmanual"
        echo "=========================================================="
        ;;

    upgrade)
        echo "🔄 Upgrading Certux Ecosystem..."
        sudo rpm-ostree upgrade
        flatpak update -y
        if distrobox list | grep -q "$CONTAINER_NAME"; then
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-get update > /dev/null 2>&1 && sudo apt-get upgrade -y"
        fi
        echo "✅ Universal Upgrade complete!"
        ;;

    repo)
        ensure_container
        if [ "$TARGET" == "list" ]; then
            echo "--- FLATPAK REPOSITORIES ---"
            flatpak remotes
            echo -e "\n--- DEBIAN SUBSYSTEM REPOSITORIES ---"
            distrobox enter "$CONTAINER_NAME" -- bash -c "cat /etc/apt/sources.list /etc/apt/sources.list.d/*.list 2>/dev/null | grep -v '^#'"
        elif [ "$TARGET" == "add" ]; then
            echo "➕ Adding repository: $EXTRA"
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-add-repository '$EXTRA' -y && sudo apt-get update"
        fi
        ;;
        
    install)
        if [ -z "$TARGET" ]; then echo "Usage: cert install <package/file>"; exit 1; fi
        
        if [[ "$TARGET" == *.AppImage || "$TARGET" == *.appimage ]]; then
            APP_DIR="$HOME/System/Apps"
            mkdir -p "$APP_DIR"
            BASENAME=$(basename "$TARGET")
            APP_NAME="${BASENAME%.*}"
            echo "📥 Securing AppImage in $APP_DIR..."
            cp "$TARGET" "$APP_DIR/$BASENAME"
            chmod +x "$APP_DIR/$BASENAME"
            DESKTOP_FILE="$HOME/.local/share/applications/certux-${APP_NAME}.desktop"
            echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=$APP_DIR/$BASENAME\nIcon=application-x-executable\nType=Application\nCategories=Utility;" > "$DESKTOP_FILE"
            echo "✅ AppImage installed!"
            exit 0
        fi

        ensure_container
        if [[ -f "$TARGET" && "$TARGET" == *.deb ]]; then
            FILE_PATH=$(realpath "$TARGET")
            echo "📥 Installing local .deb: $TARGET"
            if ! distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y '$FILE_PATH'"; then
                echo "⚠️ Resolving dependencies..."
                distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get install -f -y"
            fi
            APP_NAME=$(distrobox enter "$CONTAINER_NAME" -- bash -c "dpkg-deb -f '$FILE_PATH' Package")
        else
            echo "📥 Installing web package: $TARGET"
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y $TARGET"
            APP_NAME="$TARGET"
        fi
        
        echo "🔗 Bridging $APP_NAME to Desktop..."
        distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $APP_NAME || distrobox-export --app ${APP_NAME%-*} || true"
        echo "✅ Installed $APP_NAME!"
        ;;

    remove)
        ensure_container
        echo "🗑️ Removing $TARGET..."
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-get remove -y $TARGET"
        ;;
esac

# ONLY prompt for enter if we are running in an actual interactive terminal window.
# If running silently inside the Python GUI, exit cleanly.
if [ -t 0 ]; then
    read -p "Press Enter to exit..."
fi
