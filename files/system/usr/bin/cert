#!/usr/bin/env bash
# Certux Universal Engine v8.5 - "Silent API Routing"

GUI_MODE=false
if [ "$1" == "--gui" ]; then
    GUI_MODE=true
    shift
fi

COMMAND=$1
shift

# --- THE GLOBAL TRAFFIC COP ---
SOURCE="Auto"
if [ "$COMMAND" == "install" ] || [ "$COMMAND" == "remove" ] || [ "$COMMAND" == "launch" ]; then
    if [ "$1" == "Flatpak" ] || [ "$1" == "Debian" ]; then
        SOURCE=$1
        shift
    fi
fi

TARGET=$1
EXTRA=$2

CONTAINER_NAME="certux-legacy-layer"
BASE_IMAGE="debian:latest"
REAL_DESKTOP_DIR="$HOME/.local/share/applications"
API_LOG="/tmp/certux_api"

ensure_container() {
    if ! distrobox list | grep -q "$CONTAINER_NAME"; then
        if [ "$GUI_MODE" = false ]; then echo "📦 Initializing Certux Subsystem..."; fi
        distrobox create --name "$CONTAINER_NAME" --image "$BASE_IMAGE" --yes > /dev/null 2>&1
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo dpkg --add-architecture i386 && sudo apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common xdg-utils"
    fi
}

native_integration_cleanup() {
    if [ "$GUI_MODE" = false ]; then echo "🧹 Applying Native OS Visual Integration..."; fi
    sed -i "s/ (on ${CONTAINER_NAME})//g" "$REAL_DESKTOP_DIR/"*.desktop 2>/dev/null || true
    chmod +x "$REAL_DESKTOP_DIR/"*.desktop 2>/dev/null || true
}

# --- THE MACHINE-READABLE GUI OUTPUT (Writes to hidden file) ---
if [ "$GUI_MODE" = true ]; then
    > "$API_LOG" # Clear previous API data
    case "$COMMAND" in
        search)
            flatpak search "$TARGET" --columns=application,name,description,remotes 2>/dev/null | awk -F'\t' 'NR>1 {print "API|SEARCH|Flatpak|"$1"|"$2"|"$3"|"$4}' >> "$API_LOG"
            ensure_container >/dev/null 2>&1
            distrobox-enter -n "$CONTAINER_NAME" -- apt-cache search "$TARGET" 2>/dev/null | head -n 15 | awk -F' - ' '{print "API|SEARCH|Debian|"$1"|"$1"|"$2"|Debian Sandbox"}' >> "$API_LOG"
            ;;
        list)
            flatpak list --app --columns=application,name,origin 2>/dev/null | awk -F'\t' 'NR>1 {print "API|LIST|Flatpak|"$1"|"$2"|"$3}' >> "$API_LOG"
            ensure_container >/dev/null 2>&1
            distrobox-enter -n "$CONTAINER_NAME" -- apt-mark showmanual 2>/dev/null | awk '{print "API|LIST|Debian|"$1"|"$1"|Debian Sandbox"}' >> "$API_LOG"
            ;;
        repo)
            echo "API|REPO|Flatpak|Flathub Universal Linux Registry" >> "$API_LOG"
            ensure_container >/dev/null 2>&1
            distrobox-enter -n "$CONTAINER_NAME" -- bash -c "grep -E '^deb ' /etc/apt/sources.list /etc/apt/sources.list.d/*.list 2>/dev/null" | awk '{print "API|REPO|Debian|"$0}' >> "$API_LOG"
            ;;
    esac
    exit 0
fi

# --- STANDARD EXECUTION ENGINE ---
case "$COMMAND" in
    update-sys)
        echo "🔄 Requesting authorization for Core OS Upgrade..."
        pkexec rpm-ostree upgrade
        echo "✅ Core OS Upgrade complete! Please reboot to apply."
        ;;

    update-apps)
        echo "🔄 Upgrading App Ecosystems..."
        echo "▶ Updating Flatpaks..."
        flatpak update -y
        if distrobox list | grep -q "$CONTAINER_NAME"; then
            echo "▶ Updating Debian Subsystem..."
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update >/dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y"
        fi
        echo "✅ App Ecosystems Fully Upgraded!"
        ;;

    launch)
        echo "🚀 Launching $TARGET from $SOURCE..."
        if [ "$SOURCE" == "Flatpak" ]; then
            flatpak run "$TARGET" &
        elif [ "$SOURCE" == "Debian" ]; then
            distrobox-enter -n "$CONTAINER_NAME" -- "$TARGET" &
        fi
        echo "✅ Launch signal sent."
        ;;

    install)
        if [ -z "$TARGET" ]; then echo "Usage: cert install [Flatpak|Debian] <package/file>"; exit 1; fi
        mkdir -p "$REAL_DESKTOP_DIR"
        
        if [[ "$TARGET" == *.AppImage || "$TARGET" == *.appimage ]]; then
            BASENAME=$(basename "$TARGET")
            APP_NAME="${BASENAME%.*}"
            echo "📥 Securing AppImage..."
            cp "$TARGET" "$REAL_DESKTOP_DIR/$BASENAME"
            chmod +x "$REAL_DESKTOP_DIR/$BASENAME"
            echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=$REAL_DESKTOP_DIR/$BASENAME\nIcon=application-x-executable\nType=Application\nCategories=Utility;" > "$REAL_DESKTOP_DIR/certux-${APP_NAME}.desktop"
            echo "✅ AppImage installed!"
            native_integration_cleanup
            exit 0
        fi

        if [ "$SOURCE" == "Flatpak" ] || [[ "$SOURCE" == "Auto" && "$TARGET" == *.*.* && "$TARGET" != *.deb ]]; then
            echo "📥 Installing Native Flatpak: $TARGET..."
            if flatpak install --system -y "$TARGET"; then
                echo "✅ Flatpak $TARGET successfully installed!"
                exit 0
            else
                echo "❌ CRITICAL ERROR: Flatpak installation failed."
                exit 1
            fi
        fi

        ensure_container
        if [[ -f "$TARGET" && "$TARGET" == *.deb ]]; then
            FILE_PATH=$(realpath "$TARGET")
            echo "📥 Installing local .deb: $TARGET"
            if ! distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y '$FILE_PATH'"; then
                distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get install -f -y"
            fi
            APP_NAME=$(distrobox enter "$CONTAINER_NAME" -- bash -c "dpkg-deb -f '$FILE_PATH' Package")
        else
            echo "📥 Installing Debian package: $TARGET"
            if ! distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y $TARGET"; then
                echo "❌ CRITICAL ERROR: Package '$TARGET' not found."
                exit 1
            fi
            APP_NAME="$TARGET"
        fi
        
        echo "🔗 Bridging $APP_NAME to your desktop..."
        EXPORT_SUCCESS=false

        if distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $APP_NAME --export-path $REAL_DESKTOP_DIR" > /dev/null 2>&1; then
            EXPORT_SUCCESS=true
        else
            FOUND_DESKTOP=$(distrobox enter "$CONTAINER_NAME" -- bash -c "ls /usr/share/applications | grep -i '$APP_NAME' | head -n 1")
            if [ -n "$FOUND_DESKTOP" ]; then
                CLEAN_NAME="${FOUND_DESKTOP%.desktop}"
                if distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $CLEAN_NAME --export-path $REAL_DESKTOP_DIR" > /dev/null 2>&1; then
                    EXPORT_SUCCESS=true
                fi
            elif distrobox enter "$CONTAINER_NAME" -- bash -c "distrobox-export --app $TARGET --export-path $REAL_DESKTOP_DIR" > /dev/null 2>&1; then
                EXPORT_SUCCESS=true
            fi
        fi

        if [ "$EXPORT_SUCCESS" = false ]; then
            BRUTE_DESKTOP="$REAL_DESKTOP_DIR/certux-bruteforce-${APP_NAME}.desktop"
            echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=/usr/bin/distrobox-enter -n $CONTAINER_NAME -- $TARGET\nIcon=application-x-executable\nType=Application\nCategories=Utility;" > "$BRUTE_DESKTOP"
        fi

        echo "✅ Successfully installed and bridged!"
        native_integration_cleanup
        ;;

    remove)
        if [ -z "$TARGET" ]; then echo "Usage: cert remove [Flatpak|Debian] <package>"; exit 1; fi

        if [ "$SOURCE" == "Flatpak" ] || flatpak list --app --columns=application | grep -q "^${TARGET}$"; then
            echo "🗑️ Removing Flatpak: $TARGET..."
            flatpak uninstall --system -y "$TARGET"
            echo "✅ Removed Flatpak $TARGET."
            exit 0
        fi

        ensure_container
        echo "🗑️ Removing Debian package: $TARGET..."
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get remove -y $TARGET"
        rm -f "$REAL_DESKTOP_DIR/certux-bruteforce-${TARGET}.desktop" 2>/dev/null || true
        rm -f "$REAL_DESKTOP_DIR/${CONTAINER_NAME}-${TARGET}.desktop" 2>/dev/null || true
        echo "✅ Removed Debian package $TARGET."
        ;;
esac
