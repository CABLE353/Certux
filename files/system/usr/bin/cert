#!/usr/bin/env bash
# Certux Universal Engine v8.8 - "Unified Dev-Ops & Hardware Control"

# 1. IMMEDIATE HELP CHECK: Catch help before any shifting
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    cat << EOF
Certux Universal Engine - Command Reference
Usage: cert [COMMAND] [SOURCE] [TARGET]

Core Commands:
  install [SOURCE] [TARGET]  Install a package (Flatpak, Debian, or Native)
  remove [SOURCE] [TARGET]   Remove a package
  launch [SOURCE] [TARGET]   Launch an application
  
System Commands:
  update-sys                 Upgrade the core OS (rpm-ostree)
  update-apps                Upgrade Flatpaks and Container apps
  add-repo [REPO_LINE]       Add a new Debian repository
  toggle-driver [MOD] [ACT]  Enable/Disable kernel modules (load/unload)
  
Status & Info:
  repo                       List all configured repositories
  list                       List installed applications
  search [QUERY]             Search for packages
  deps [SOURCE] [TARGET]     List application dependencies
  -h, --help                 Show this help message
EOF
    exit 0
fi

# 2. GUI MODE DETECTION
GUI_MODE=false
if [ "$1" == "--gui" ]; then
    GUI_MODE=true
    shift
fi

COMMAND=$1
shift

SOURCE="Auto"
# Handle the source argument if provided
if [ "$COMMAND" == "install" ] || [ "$COMMAND" == "remove" ] || [ "$COMMAND" == "launch" ] || [ "$COMMAND" == "deps" ]; then
    if [ "$1" == "Flatpak" ] || [ "$1" == "Debian" ]; then
        SOURCE=$1
        shift
    fi
fi

TARGET=$1
EXTRA=$2

CONTAINER_NAME="certux-legacy-layer"
BASE_IMAGE="debian:latest"
REAL_DESKTOP_DIR="$HOME/.local/share/applications"
API_LOG="/tmp/certux_api"

ensure_container() {
    if ! distrobox list | grep -q "$CONTAINER_NAME"; then
        if [ "$GUI_MODE" = false ]; then echo "📦 Initializing Certux Subsystem..."; fi
        distrobox create --name "$CONTAINER_NAME" --image "$BASE_IMAGE" --yes > /dev/null 2>&1
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo dpkg --add-architecture i386 && sudo apt-get update > /dev/null 2>&1 && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common xdg-utils"
        distrobox enter "$CONTAINER_NAME" -- bash -c 'cat <<EOF | sudo tee /etc/apt/sources.list
deb http://deb.debian.org/debian stable main contrib non-free non-free-firmware
deb http://deb.debian.org/debian stable-updates main contrib non-free non-free-firmware
deb http://security.debian.org/debian-security stable-security main contrib non-free non-free-firmware
EOF'
        distrobox enter "$CONTAINER_NAME" -- sudo apt-get update > /dev/null 2>&1
    fi
}

native_integration_cleanup() {
    if [ "$GUI_MODE" = false ]; then echo "🧹 Applying Native OS Visual Integration..."; fi
    sed -i "s/ (on ${CONTAINER_NAME})//g" "$REAL_DESKTOP_DIR/"*.desktop 2>/dev/null || true
    chmod +x "$REAL_DESKTOP_DIR/"*.desktop 2>/dev/null || true
}

# --- THE MACHINE-READABLE GUI OUTPUT ---
if [ "$GUI_MODE" = true ]; then
    > "$API_LOG"
    case "$COMMAND" in
        search)
            flatpak search "$TARGET" --columns=application,name,description,remotes 2>/dev/null | awk -F'\t' 'NR>1 {print "API|SEARCH|Flatpak|"$1"|"$2"|"$3"|"$4}' >> "$API_LOG"
            ensure_container >/dev/null 2>&1
            distrobox-enter -n "$CONTAINER_NAME" -- apt-cache search "$TARGET" 2>/dev/null | head -n 15 | awk -F' - ' '{print "API|SEARCH|Debian|"$1"|"$1"|"$2"|Debian Sandbox"}' >> "$API_LOG"
            ;;
        list)
            flatpak list --app --columns=application,name,origin 2>/dev/null | awk -F'\t' 'NR>1 {print "API|LIST|Flatpak|"$1"|"$2"|"$3}' >> "$API_LOG"
            ensure_container >/dev/null 2>&1
            distrobox-enter -n "$CONTAINER_NAME" -- apt-mark showmanual 2>/dev/null | awk '{print "API|LIST|Debian|"$1"|"$1"|Debian Sandbox"}' >> "$API_LOG"
            ;;
        repo)
            echo "API|REPO|Flatpak|Flathub Universal Linux Registry" >> "$API_LOG"
            ensure_container >/dev/null 2>&1
            distrobox-enter -n "$CONTAINER_NAME" -- bash -c "grep -rE '^deb ' /etc/apt/sources.list*" | awk '{print "API|REPO|Debian|"$0}' >> "$API_LOG"
            ;;
        deps)
            if [ "$SOURCE" == "Flatpak" ]; then
                RUNTIME=$(flatpak info "$TARGET" 2>/dev/null | grep "Runtime:" | awk '{print $2}')
                SDK=$(flatpak info "$TARGET" 2>/dev/null | grep "Sdk:" | awk '{print $2}')
                if [ -n "$RUNTIME" ]; then echo "API|DEPS|Flatpak|$RUNTIME|Flatpak Runtime Base|System Component" >> "$API_LOG"; fi
                if [ -n "$SDK" ]; then echo "API|DEPS|Flatpak|$SDK|Flatpak SDK Base|System Component" >> "$API_LOG"; fi
            elif [ "$SOURCE" == "Debian" ]; then
                ensure_container >/dev/null 2>&1
                distrobox-enter -n "$CONTAINER_NAME" -- apt-cache depends "$TARGET" 2>/dev/null | grep "Depends:" | awk '{print $2}' | head -n 8 | while read -r dep; do
                    echo "API|DEPS|Debian|$dep|Debian Library|System Component" >> "$API_LOG"
                done
            fi
            ;;
    esac
    exit 0
fi

# --- STANDARD EXECUTION ENGINE ---
case "$COMMAND" in
    update-sys)
        if pkexec rpm-ostree upgrade; then echo "✅ OS Updated."; else exit 1; fi
        ;;
    update-apps)
        flatpak update -y
        if distrobox list | grep -q "$CONTAINER_NAME"; then
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-get update && sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y"
        fi
        ;;
    launch)
        if [ "$SOURCE" == "Flatpak" ]; then flatpak run "$TARGET"; else distrobox-enter -n "$CONTAINER_NAME" -- "$TARGET"; fi
        ;;
    install)
        if [ -z "$TARGET" ]; then exit 1; fi
        if [[ "$TARGET" == *.AppImage ]]; then
            BASENAME=$(basename "$TARGET")
            APP_NAME="${BASENAME%.*}"
            cp "$TARGET" "$REAL_DESKTOP_DIR/$BASENAME"
            chmod +x "$REAL_DESKTOP_DIR/$BASENAME"
            echo -e "[Desktop Entry]\nName=$APP_NAME\nExec=$REAL_DESKTOP_DIR/$BASENAME\nIcon=application-x-executable\nType=Application\nCategories=Utility;" > "$REAL_DESKTOP_DIR/certux-${APP_NAME}.desktop"
            native_integration_cleanup
            exit 0
        fi
        if [ "$SOURCE" == "Flatpak" ] || [[ "$SOURCE" == "Auto" && "$TARGET" == *.*.* ]]; then
            flatpak install --system -y "$TARGET"
        else
            ensure_container
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-get update && sudo DEBIAN_FRONTEND=noninteractive apt-get install -y $TARGET"
            distrobox enter "$CONTAINER_NAME" -- distrobox-export --app "$TARGET" --export-path "$REAL_DESKTOP_DIR" > /dev/null 2>&1 || true
            native_integration_cleanup
        fi
        ;;
    add-repo)
        ensure_container
        distrobox enter "$CONTAINER_NAME" -- bash -c "sudo apt-get update && sudo apt-get install -y software-properties-common && sudo add-apt-repository -y '$1' && sudo apt-get update"
        ;;
    toggle-driver)
        if [ "$2" == "unload" ]; then pkexec modprobe -r "$1"; else pkexec modprobe "$1"; fi
        ;;
    remove)
        if [ "$SOURCE" == "Flatpak" ]; then
            flatpak uninstall --system -y "$TARGET"
        else
            ensure_container
            distrobox enter "$CONTAINER_NAME" -- bash -c "sudo DEBIAN_FRONTEND=noninteractive apt-get remove -y $TARGET"
        fi
        ;;
    *)
        echo "Error: Command not recognized. Use 'cert --help' for usage."
        exit 1
        ;;
esac
