#!/usr/bin/env python3
import gi
import sys
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw
import subprocess

class DeviceManagerWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Certux Device Manager")
        self.set_default_size(600, 500)
        
        # 1. Create a top-level Box
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        
        # 2. Add an Adw.HeaderBar
        header = Adw.HeaderBar()
        main_box.append(header)
        
        # 3. Add the ScrolledWindow as the content
        self.list_box = Gtk.ListBox()
        self.list_box.add_css_class("boxed-list")
        
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_child(self.list_box)
        scrolled.set_vexpand(True)
        main_box.append(scrolled)
        
        self.set_content(main_box)
        self.load_devices()

    def load_devices(self):
        # We run the command and parse the module name
        # Format: Name | DriverModule | Status
        result = subprocess.run(["/usr/sbin/lspci", "-k"], capture_output=True, text=True)
        
        # Simple parser logic for demo purposes
        for line in result.stdout.splitlines():
            if "Kernel driver in use:" in line:
                driver = line.split(": ")[1]
                
                # Create the UI Row
                row = Adw.ActionRow(title=f"Driver: {driver}")
                switch = Gtk.Switch()
                switch.set_active(True) # Assuming active if found
                switch.connect("state-set", self.on_switch_toggled, driver)
                
                row.add_suffix(switch)
                self.list_box.append(row)

    def on_switch_toggled(self, switch, state, driver):
        action = "load" if state else "unload"
        result = subprocess.run(["pkexec", "cert", "toggle-driver", driver, action], 
                                capture_output=True, text=True)
        
        if result.returncode != 0:
            # Revert the switch since the command failed
            switch.set_active(not state)
            # Show a nice warning dialog
            self.show_error_dialog("Driver Busy", "This driver is currently in use.")
        return False
class DeviceManagerApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="com.certux.device-manager")

    def do_activate(self):
        win = DeviceManagerWindow(self)
        win.present()

if __name__ == "__main__":
    app = DeviceManagerApp()
    app.run(sys.argv)
