#!/usr/bin/env python3
import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw
import subprocess

class DeviceManagerWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Certux Device Manager")
        self.set_default_size(600, 500)
        
        self.list_box = Gtk.ListBox()
        self.list_box.add_css_class("boxed-list")
        
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_child(self.list_box)
        
        # Header bar for the standalone window
        header = Adw.HeaderBar()
        self.set_titlebar(header)
        
        self.set_content(scrolled)
        self.load_devices()

    def load_devices(self):
        # We query the hardware directly
        try:
            result = subprocess.run(["lspci"], capture_output=True, text=True)
            for line in result.stdout.splitlines():
                if line:
                    self.list_box.append(Adw.ActionRow(title=line))
        except Exception as e:
            self.list_box.append(Adw.ActionRow(title=f"Error: {str(e)}"))

class DeviceManagerApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="com.certux.device-manager")

    def do_activate(self):
        win = DeviceManagerWindow(self)
        win.present()

if __name__ == "__main__":
    app = DeviceManagerApp()
    app.run(sys.argv)
