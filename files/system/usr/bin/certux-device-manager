import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw
import subprocess

class DeviceManagerPage(Adw.PreferencesPage):
    def __init__(self):
        super().__init__(title="Device Manager")
        self.list_box = Gtk.ListBox()
        self.list_box.add_css_class("boxed-list")
        self.list_box.set_margin_start(20)
        self.list_box.set_margin_end(20)
        self.list_box.set_margin_top(20)
        
        group = Adw.PreferencesGroup(title="System Hardware")
        group.add(self.list_box)
        self.add(group)
        
        self.load_devices()

    def load_devices(self):
        # Run our data helper via the distrobox container
        result = subprocess.run(
            ["distrobox", "enter", "certux-legacy-layer", "--", "/usr/bin/certux-device-manager-data"],
            capture_output=True, text=True
        )
        
        for line in result.stdout.splitlines():
            if line and "---" not in line and "DEVICES:" not in line:
                row = Adw.ActionRow(title=line)
                self.list_box.append(row)
