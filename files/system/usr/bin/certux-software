#!/usr/bin/env python3
import gi
import subprocess
import sys
import threading
import os
import re

gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib

class CertuxSoftwareWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Certux Software Center")
        self.set_default_size(950, 800)

        # Batch Operations Storage
        self.install_queue = []
        self.search_items = []
        self.installed_items = []
        self.is_processing = False

        self.view_stack = Adw.ViewStack()
        
        page_software = self.create_software_page()
        page_installed = self.create_installed_page()
        page_repos = self.create_repo_page()
        
        self.view_stack.add_titled(page_software, "software", "Store & Search")
        self.view_stack.add_titled(page_installed, "installed", "Installed Apps")
        self.view_stack.add_titled(page_repos, "repos", "Repositories")

        view_switcher = Adw.ViewSwitcherTitle(stack=self.view_stack)
        header = Adw.HeaderBar()
        header.set_title_widget(view_switcher)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        vbox.append(header)
        
        # --- SMART PROGRESS BAR ---
        self.progress_bar = Gtk.ProgressBar()
        self.progress_bar.set_visible(False)
        vbox.append(self.progress_bar)

        vbox.append(self.view_stack)

        # --- VERBOSE CONSOLE ---
        bottom_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        bottom_bar.set_margin_start(15)
        bottom_bar.set_margin_end(15)
        bottom_bar.set_margin_top(10)
        bottom_bar.set_margin_bottom(10)
        bottom_bar.set_halign(Gtk.Align.END)

        self.verbose_toggle = Gtk.ToggleButton(label="Verbose Output")
        self.verbose_toggle.connect("toggled", lambda b: self.console_revealer.set_reveal_child(b.get_active()))
        bottom_bar.append(self.verbose_toggle)

        self.console_revealer = Gtk.Revealer()
        self.console_revealer.set_transition_type(Gtk.RevealerTransitionType.SLIDE_UP)
        self.console_revealer.set_reveal_child(False) # Hidden by default!

        console_inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        console_header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        console_header.set_margin_start(15)
        console_header.set_margin_end(15)
        c_label = Gtk.Label(label="<b>System Output Engine</b>", use_markup=True)
        c_label.set_hexpand(True)
        c_label.set_halign(Gtk.Align.START)
        clear_btn = Gtk.Button(label="Clear")
        clear_btn.connect("clicked", lambda b: self.console_buffer.set_text(""))
        console_header.append(c_label)
        console_header.append(clear_btn)
        
        self.console_buffer = Gtk.TextBuffer()
        self.console_view = Gtk.TextView(buffer=self.console_buffer)
        self.console_view.set_editable(False)
        self.console_view.set_wrap_mode(Gtk.WrapMode.WORD)
        self.console_view.set_monospace(True)
        self.console_view.add_css_class("card")

        scroll = Gtk.ScrolledWindow()
        scroll.set_child(self.console_view)
        scroll.set_size_request(-1, 200)
        scroll.set_margin_start(15)
        scroll.set_margin_end(15)
        scroll.set_margin_bottom(15)

        console_inner.append(console_header)
        console_inner.append(scroll)
        self.console_revealer.set_child(console_inner)
        
        vbox.append(Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL))
        vbox.append(bottom_bar)
        vbox.append(self.console_revealer)
        self.set_content(vbox)

        if len(sys.argv) > 1:
            self.queue_command(f"/usr/bin/cert install Auto '{sys.argv[1]}'")
            
        self.refresh_installed()
        self.refresh_repos()

    # ==========================================
    # TAB 1: SEARCH PAGE
    # ==========================================
    def create_software_page(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        box.set_margin_top(20)
        box.set_margin_start(40)
        box.set_margin_end(40)

        box.append(Gtk.Label(label="<span size='xx-large' weight='bold'>App Discovery</span>", use_markup=True))

        search_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        search_box.set_halign(Gtk.Align.CENTER)
        self.search_entry = Gtk.Entry(placeholder_text="Search Flatpak and Debian repositories...")
        self.search_entry.set_width_chars(40)
        search_btn = Gtk.Button(label="Search")
        search_btn.connect("clicked", self.on_search_clicked)
        
        # Batch Install Button
        self.btn_batch_install = Gtk.Button(label="Install Selected Apps")
        self.btn_batch_install.add_css_class("suggested-action")
        self.btn_batch_install.connect("clicked", self.on_batch_install_clicked)
        
        search_box.append(self.search_entry)
        search_box.append(search_btn)
        search_box.append(self.btn_batch_install)
        box.append(search_box)

        self.results_list = Gtk.ListBox()
        self.results_list.add_css_class("boxed-list")
        self.results_list.set_selection_mode(Gtk.SelectionMode.NONE)
        results_scroll = Gtk.ScrolledWindow()
        results_scroll.set_child(self.results_list)
        results_scroll.set_vexpand(True)
        box.append(results_scroll)

        return box

    def on_search_clicked(self, button):
        query = self.search_entry.get_text()
        if not query: return
        self._clear_list(self.results_list)
        self.results_list.append(Adw.ActionRow(title="Querying repositories..."))
        
        self.progress_bar.set_visible(True)
        def worker():
            subprocess.run(f"/usr/bin/cert --gui search '{query}'", shell=True)
            results_data = []
            if os.path.exists("/tmp/certux_api"):
                with open("/tmp/certux_api", "r") as f:
                    for line in f:
                        if line.startswith("API|SEARCH|"):
                            results_data.append(line.strip())
            GLib.idle_add(self.populate_search_results, results_data)
        threading.Thread(target=worker, daemon=True).start()

    def populate_search_results(self, results_data):
        self.progress_bar.set_visible(False)
        self._clear_list(self.results_list)
        self.search_items = []
        has_results = False
        
        for line in results_data:
            has_results = True
            parts = line.split('|', 6)
            if len(parts) >= 7:
                source, app_id, name, desc, repo = parts[2], parts[3], parts[4], parts[5], parts[6]
                
                row = Adw.ActionRow(title=f"{name} [{source}]", subtitle=desc)
                
                # Checkbox for Batch Processing
                checkbox = Gtk.CheckButton()
                checkbox.set_valign(Gtk.Align.CENTER)
                row.add_prefix(checkbox)
                
                self.search_items.append({
                    'checkbox': checkbox,
                    'source': source,
                    'app_id': app_id
                })
                
                btn_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                btn_box.set_valign(Gtk.Align.CENTER)
                btn_box.set_margin_top(5)
                btn_box.set_margin_bottom(5)
                
                btn = Gtk.Button(label="Install")
                btn.add_css_class("pill")
                btn.connect("clicked", lambda b, s=source, pkg=app_id: self.queue_command(f"/usr/bin/cert install {s} '{pkg}'"))
                
                repo_label = Gtk.Label(label=f"<span size='x-small' foreground='gray'>Repo: {repo}</span>", use_markup=True)
                
                btn_box.append(btn)
                btn_box.append(repo_label)
                row.add_suffix(btn_box)
                self.results_list.append(row)
                    
        if not has_results:
            self.results_list.append(Adw.ActionRow(title="No results found."))

    def on_batch_install_clicked(self, button):
        for item in self.search_items:
            if item['checkbox'].get_active():
                self.queue_command(f"/usr/bin/cert install {item['source']} '{item['app_id']}'")
                item['checkbox'].set_active(False)

    # ==========================================
    # TAB 2: INSTALLED PAGE
    # ==========================================
    def create_installed_page(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        box.set_margin_top(20)
        box.set_margin_start(40)
        box.set_margin_end(40)

        header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        header_box.append(Gtk.Label(label="<span size='x-large' weight='bold'>System Operations</span>", use_markup=True, hexpand=True, halign=Gtk.Align.START))
        
        self.btn_batch_remove = Gtk.Button(label="Remove Selected")
        self.btn_batch_remove.add_css_class("destructive-action")
        self.btn_batch_remove.connect("clicked", self.on_batch_remove_clicked)
        
        up_apps_btn = Gtk.Button(label="Update All Apps")
        up_apps_btn.connect("clicked", lambda b: self.queue_command("/usr/bin/cert update-apps"))
        
        up_sys_btn = Gtk.Button(label="Update Core OS")
        up_sys_btn.add_css_class("suggested-action")
        up_sys_btn.connect("clicked", lambda b: self.queue_command("/usr/bin/cert update-sys"))
        
        ref_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        ref_btn.connect("clicked", lambda b: self.refresh_installed())
        
        header_box.append(self.btn_batch_remove)
        header_box.append(up_apps_btn)
        header_box.append(up_sys_btn)
        header_box.append(ref_btn)
        box.append(header_box)

        self.installed_list = Gtk.ListBox()
        self.installed_list.add_css_class("boxed-list")
        self.installed_list.set_selection_mode(Gtk.SelectionMode.NONE)
        inst_scroll = Gtk.ScrolledWindow()
        inst_scroll.set_child(self.installed_list)
        inst_scroll.set_vexpand(True)
        box.append(inst_scroll)

        return box

    def refresh_installed(self):
        self._clear_list(self.installed_list)
        self.installed_list.append(Adw.ActionRow(title="Scanning installed apps..."))
        
        def worker():
            subprocess.run("/usr/bin/cert --gui list", shell=True)
            results_data = []
            if os.path.exists("/tmp/certux_api"):
                with open("/tmp/certux_api", "r") as f:
                    for line in f:
                        if line.startswith("API|LIST|"):
                            results_data.append(line.strip())
            GLib.idle_add(self.populate_installed, results_data)
        threading.Thread(target=worker, daemon=True).start()

    def populate_installed(self, results_data):
        self._clear_list(self.installed_list)
        self.installed_items = []
        has_results = False
        
        for line in results_data:
            has_results = True
            parts = line.split('|', 5)
            if len(parts) >= 6:
                source, app_id, name, repo = parts[2], parts[3], parts[4], parts[5]
                
                row = Adw.ActionRow(title=f"{name} [{source}]", subtitle=f"Repo: {repo} | ID: {app_id}")
                
                # Checkbox for Batch Processing
                checkbox = Gtk.CheckButton()
                checkbox.set_valign(Gtk.Align.CENTER)
                row.add_prefix(checkbox)
                
                self.installed_items.append({
                    'checkbox': checkbox,
                    'source': source,
                    'app_id': app_id
                })
                
                action_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=5)
                action_box.set_valign(Gtk.Align.CENTER)
                action_box.set_margin_top(10)
                action_box.set_margin_bottom(10)
                
                open_btn = Gtk.Button(label="Open")
                open_btn.add_css_class("suggested-action")
                open_btn.add_css_class("pill")
                open_btn.connect("clicked", lambda b, s=source, pkg=app_id: self.queue_command(f"/usr/bin/cert launch {s} '{pkg}'"))
                
                rem_btn = Gtk.Button(label="Remove")
                rem_btn.add_css_class("destructive-action")
                rem_btn.add_css_class("pill")
                rem_btn.connect("clicked", lambda b, s=source, pkg=app_id: self.queue_command(f"/usr/bin/cert remove {s} '{pkg}'"))
                
                action_box.append(open_btn)
                action_box.append(rem_btn)
                row.add_suffix(action_box)
                self.installed_list.append(row)
                
        if not has_results:
            self.installed_list.append(Adw.ActionRow(title="No graphical applications found."))

    def on_batch_remove_clicked(self, button):
        for item in self.installed_items:
            if item['checkbox'].get_active():
                self.queue_command(f"/usr/bin/cert remove {item['source']} '{item['app_id']}'")
                item['checkbox'].set_active(False)

    # ==========================================
    # TAB 3: REPOS PAGE
    # ==========================================
    def create_repo_page(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        box.set_margin_top(20)
        box.set_margin_start(40)
        box.set_margin_end(40)

        header_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        header_box.append(Gtk.Label(label="<span size='x-large' weight='bold'>Repository Management</span>", use_markup=True, hexpand=True, halign=Gtk.Align.START))
        
        ref_btn = Gtk.Button(icon_name="view-refresh-symbolic")
        ref_btn.connect("clicked", lambda b: self.refresh_repos())
        header_box.append(ref_btn)
        box.append(header_box)

        add_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        add_box.set_halign(Gtk.Align.CENTER)
        self.repo_entry = Gtk.Entry(placeholder_text="ppa:name/repo OR deb http://...")
        self.repo_entry.set_width_chars(40)
        add_btn = Gtk.Button(label="Add Debian Repo")
        add_btn.connect("clicked", lambda b: self.queue_command(f"/usr/bin/cert repo add '{self.repo_entry.get_text()}'"))
        add_box.append(self.repo_entry)
        add_box.append(add_btn)
        box.append(add_box)

        self.repo_list = Gtk.ListBox()
        self.repo_list.add_css_class("boxed-list")
        self.repo_list.set_selection_mode(Gtk.SelectionMode.NONE)
        repo_scroll = Gtk.ScrolledWindow()
        repo_scroll.set_child(self.repo_list)
        repo_scroll.set_vexpand(True)
        box.append(repo_scroll)

        return box

    def refresh_repos(self):
        self._clear_list(self.repo_list)
        self.repo_list.append(Adw.ActionRow(title="Scanning repositories..."))
        
        def worker():
            subprocess.run("/usr/bin/cert --gui repo", shell=True)
            results_data = []
            if os.path.exists("/tmp/certux_api"):
                with open("/tmp/certux_api", "r") as f:
                    for line in f:
                        if line.startswith("API|REPO|"):
                            results_data.append(line.strip())
            GLib.idle_add(self.populate_repos, results_data)
        threading.Thread(target=worker, daemon=True).start()

    def populate_repos(self, results_data):
        self._clear_list(self.repo_list)
        has_results = False
        for line in results_data:
            has_results = True
            parts = line.split('|', 3)
            if len(parts) >= 4:
                source, url = parts[2], parts[3]
                row = Adw.ActionRow(title=url, subtitle=f"Source: {source} Registry")
                
                status = Gtk.Label(label="<span size='small' foreground='green'>● Active</span>", use_markup=True)
                status.set_valign(Gtk.Align.CENTER)
                row.add_suffix(status)
                
                self.repo_list.append(row)
                
        if not has_results:
            self.repo_list.append(Adw.ActionRow(title="No repositories found."))

    # ==========================================
    # CORE BATCH PROCESSOR & PROGRESS TRACKER
    # ==========================================
    def _clear_list(self, listbox):
        while listbox.get_first_child() is not None:
            listbox.remove(listbox.get_first_child())

    def queue_command(self, command):
        self.install_queue.append(command)
        if not self.is_processing:
            self.process_next_queue()

    def process_next_queue(self):
        if not self.install_queue:
            self.is_processing = False
            self.progress_bar.set_visible(False)
            return
            
        self.is_processing = True
        command = self.install_queue.pop(0)
        
        self.progress_bar.set_visible(True)
        self.progress_bar.set_fraction(0.0)
        self.console_buffer.insert(self.console_buffer.get_end_iter(), f"\n🚀 Batch Execution Started: {command}\n")
        self.scroll_to_bottom()
        
        def worker():
            process = subprocess.Popen(command, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
            
            # The Character-by-Character Parser (Captures real-time progress)
            current_line = ""
            while True:
                char = process.stdout.read(1)
                if not char:
                    break
                    
                if char == '\n' or char == '\r':
                    line = current_line.strip()
                    if line:
                        GLib.idle_add(self.append_console, line + "\n")
                        # Hunts for numbers attached to a percent sign
                        match = re.search(r'(\d+)%', line)
                        if match:
                            val = float(match.group(1)) / 100.0
                            GLib.idle_add(self.progress_bar.set_fraction, val)
                        else:
                            # If no percent is found, sweep the bar back and forth
                            GLib.idle_add(self.progress_bar.pulse)
                    current_line = ""
                else:
                    current_line += char

            process.wait()
            if process.returncode == 0:
                GLib.idle_add(self.append_console, "\n✅ Task Finished Successfully.\n")
            else:
                GLib.idle_add(self.append_console, f"\n❌ Task Failed (Error Code: {process.returncode}).\n")
                
            if "install" in command or "remove" in command or "update" in command:
                GLib.idle_add(self.refresh_installed)
                
            # Instantly fire the next app in the batch queue!
            GLib.idle_add(self.process_next_queue)

        threading.Thread(target=worker, daemon=True).start()

    def append_console(self, text):
        it = self.console_buffer.get_end_iter()
        self.console_buffer.insert(it, text)
        self.scroll_to_bottom()
        
    def scroll_to_bottom(self):
        mark = self.console_buffer.create_mark("end", self.console_buffer.get_end_iter(), False)
        self.console_view.scroll_to_mark(mark, 0.0, True, 0.0, 1.0)

class CertuxApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="com.certux.software")

    def do_activate(self):
        win = CertuxSoftwareWindow(self)
        win.present()

app = CertuxApp()
app.run(None)
