#!/usr/bin/env python3
import subprocess
import threading
import os
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib, Pango

class CertuxSoftwareCenter(Gtk.Window):
    def __init__(self):
        super().__init__(title="Certux Software Center")
        self.set_default_size(900, 600)
        self.set_border_width(10)

        # Main Layout
        self.main_layout = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        self.add(self.main_layout)

        # --- Header Section (Windows Style) ---
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        self.search_entry = Gtk.SearchEntry(placeholder_text="Search for apps (e.g. Chrome, Steam, VLC)...")
        self.search_entry.connect("activate", self.on_search_clicked)
        header.pack_start(self.search_entry, True, True, 0)

        self.btn_search = Gtk.Button(label="Search")
        self.btn_search.get_style_context().add_class("suggested-action")
        self.btn_search.connect("clicked", self.on_search_clicked)
        header.pack_start(self.btn_search, False, False, 0)
        self.main_layout.pack_start(header, False, False, 0)

        # --- Progress Bar (Hidden by default) ---
        self.progress_bar = Gtk.ProgressBar()
        self.progress_bar.set_no_show_all(True)
        self.main_layout.pack_start(self.progress_bar, False, False, 0)

        # --- App List ---
        self.store = Gtk.ListStore(str, str, str, str, str) # Source, ID, Name, Desc, Origin
        self.treeview = Gtk.TreeView(model=self.store)
        
        for i, column_title in enumerate(["Source", "App ID", "Name", "Description"]):
            renderer = Gtk.CellRendererText()
            if i == 3: renderer.set_property("ellipsize", Pango.EllipsizeMode.END)
            column = Gtk.TreeViewColumn(column_title, renderer, text=i)
            self.treeview.append_column(column)

        scroll_tree = Gtk.ScrolledWindow()
        scroll_tree.set_vexpand(True)
        scroll_tree.add(self.treeview)
        self.main_layout.pack_start(scroll_tree, True, True, 0)

        # --- Action Buttons ---
        action_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        self.btn_install = Gtk.Button(label="Install Selected")
        self.btn_install.connect("clicked", self.on_install_clicked)
        action_box.pack_start(self.btn_install, True, True, 0)

        self.btn_update = Gtk.Button(label="Check for Updates")
        self.btn_update.connect("clicked", self.on_update_clicked)
        action_box.pack_start(self.btn_update, True, True, 0)
        self.main_layout.pack_start(action_box, False, False, 0)

        # --- Hidden Verbose Console ---
        self.expander = Gtk.Expander(label="Show Technical Details")
        self.console_output = Gtk.TextView()
        self.console_output.set_editable(False)
        self.console_output.set_monospace(True)
        scroll_console = Gtk.ScrolledWindow()
        scroll_console.set_min_content_height(150)
        scroll_console.add(self.console_output)
        self.expander.add(scroll_console)
        self.main_layout.pack_start(self.expander, False, False, 0)

        self.show_all()
        self.progress_bar.hide()

    def log(self, text):
        GLib.idle_add(self._append_text, text)

    def _append_text(self, text):
        buffer = self.console_output.get_buffer()
        buffer.insert(buffer.get_end_iter(), text + "\n")
        # Auto-scroll to bottom
        adj = self.console_output.get_parent().get_vadjustment()
        adj.set_value(adj.get_upper())

    def start_loading(self):
        self.progress_bar.show()
        self.btn_search.set_sensitive(False)
        self.pulse_id = GLib.timeout_add(100, self.do_pulse)

    def stop_loading(self):
        self.progress_bar.hide()
        self.btn_search.set_sensitive(True)
        if hasattr(self, 'pulse_id'):
            GLib.source_remove(self.pulse_id)

    def do_pulse(self):
        self.progress_bar.pulse()
        return True

    def on_search_clicked(self, widget):
        query = self.search_entry.get_text()
        if not query: return
        self.store.clear()
        self.start_loading()
        threading.Thread(target=self.run_search, args=(query,), daemon=True).start()

    def run_search(self, query):
        self.log(f"🔎 Searching for: {query}...")
        subprocess.run(["cert", "--gui", "search", query])
        
        # Read from the hidden API file
        if os.path.exists("/tmp/certux_api"):
            with open("/tmp/certux_api", "r") as f:
                for line in f:
                    if line.startswith("API|SEARCH|"):
                        parts = line.strip().split("|")
                        GLib.idle_add(self.store.append, [parts[2], parts[3], parts[4], parts[5], parts[6]])
        
        GLib.idle_add(self.stop_loading)

    def on_install_clicked(self, widget):
        selection = self.treeview.get_selection()
        model, treeiter = selection.get_selected()
        if treeiter:
            source, app_id = model[treeiter][0], model[treeiter][1]
            self.start_loading()
            threading.Thread(target=self.run_command, args=(["cert", "install", source, app_id],), daemon=True).start()

    def on_update_clicked(self, widget):
        self.start_loading()
        threading.Thread(target=self.run_command, args=(["cert", "update-apps"],), daemon=True).start()

    def run_command(self, cmd):
        process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
        for line in process.stdout:
            self.log(line.strip())
        process.wait()
        GLib.idle_add(self.stop_loading)

if __name__ == "__main__":
    win = CertuxSoftwareCenter()
    win.connect("destroy", Gtk.main_quit)
    Gtk.main()
