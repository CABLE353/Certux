[Unit]
Description=Certux Background Package Cache Updater
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/bash -c 'flatpak update --appstream -y; if distrobox list | grep -q certux-legacy-layer; then distrobox enter certux-legacy-layer -- bash -c "sudo apt-get update > /dev/null 2>&1"; fi'

[Install]
WantedBy=default.target
